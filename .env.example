# ==============================================================================
# NOMEN ENVIRONMENT CONFIGURATION TEMPLATE (.env.example)
# Version: 1.0.0
#
# Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in ALL values marked as REQUIRED before deploying to production.
# 3. NEVER commit the actual .env file to git (it is in .gitignore).
# 4. Use a secrets manager (AWS Secrets Manager, Vault, etc.) in production.
#
# Generate secure random keys:
#   openssl rand -hex 32          # 64-char hex secret key
#   openssl rand -base64 32       # base64 encoded key
# ==============================================================================


# ---- Environment ----
# Options: development | staging | testing | production
ENV=development


# ==============================================================================
# DATABASE — PostgreSQL
# ==============================================================================

# Database password (REQUIRED in production)
DB_PASSWORD=secure_dev_password_change_me

# Full asyncpg database URL (auto-constructed in docker-compose from DB_PASSWORD)
DATABASE_URL=postgresql+asyncpg://nomen_user:secure_dev_password_change_me@localhost:5432/nomen_db


# ==============================================================================
# CACHE & TASK QUEUE — Redis
# ==============================================================================

REDIS_URL=redis://localhost:6379/0


# ==============================================================================
# SECURITY & AUTHENTICATION
# ==============================================================================

# JWT signing secret (REQUIRED — generate with: openssl rand -hex 32)
SECRET_KEY=insecure_dev_key_replace_with_openssl_rand_hex_32_in_production

# NextAuth secret (REQUIRED for Next.js sessions)
NEXTAUTH_SECRET=insecure_nextauth_secret_replace_in_production
NEXTAUTH_URL=http://localhost:3000

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000


# ==============================================================================
# AI PROVIDER KEYS
# ==============================================================================

# Google Gemini (primary)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (failover / optional)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude (failover / optional)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=


# ==============================================================================
# BILLING — Stripe
# ==============================================================================

# Stripe secret key
# Test: sk_test_... | Production: sk_live_...
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key_here

# Stripe webhook signing secret (from Stripe dashboard)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe price IDs
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_id
STRIPE_PRICE_STARTER_ANNUAL=price_starter_annual_id
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_PRO_ANNUAL=price_pro_annual_id
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly_id


# ==============================================================================
# EMAIL — SMTP
# ==============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@nomen.ai
SMTP_PASSWORD=your_smtp_app_password_here
SMTP_FROM=Nomen <noreply@nomen.ai>


# ==============================================================================
# STORAGE — Cloudflare R2 / S3-compatible
# ==============================================================================

S3_BUCKET=nomen-assets
S3_REGION=auto
S3_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your_r2_access_key_id
S3_SECRET_ACCESS_KEY=your_r2_secret_access_key
S3_PUBLIC_URL=https://assets.nomen.ai


# ==============================================================================
# MONITORING & OBSERVABILITY
# ==============================================================================

# Grafana admin credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana_password

# Flower (Celery monitoring) credentials
FLOWER_USER=admin
FLOWER_PASSWORD=change_me_flower_password

# Slack webhook for AlertManager
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url


# ==============================================================================
# RATE LIMITING
# ==============================================================================

RATE_LIMIT_PER_MINUTE=60


# ==============================================================================
# FRONTEND PUBLIC VARIABLES
# These are embedded in the Next.js build — do NOT put secrets here
# ==============================================================================

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key


# ==============================================================================
# FEATURE FLAGS (optional)
# ==============================================================================

MAINTENANCE_MODE=false
