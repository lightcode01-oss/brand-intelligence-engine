# ==============================================================================
# NOMEN ENVIRONMENT CONFIGURATION TEMPLATE (.env.example)
#
# Instructions:
# 1. Copy this file to '.env' in your local environment.
# 2. Update the variable values to match your development parameters.
# 3. NEVER commit the actual '.env' file containing real secrets to git.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE CONFIGURATIONS (PostgreSQL)
# ------------------------------------------------------------------------------
# PostgreSQL database password (Required)
DB_PASSWORD=secure_dev_password_change_me

# ------------------------------------------------------------------------------
# 2. CACHE & TASK QUEUE CONFIGURATIONS (Redis)
# ------------------------------------------------------------------------------
# Redis connection URL (Used by FastAPI and Celery worker)
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------------------
# 3. AI SERVICES CONFIGURATIONS
# ------------------------------------------------------------------------------
# Gemini API Key (Required for name generation workflows)
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_goes_here

# ------------------------------------------------------------------------------
# 4. SECURITY & AUTHENTICATION CONFIGURATIONS
# ------------------------------------------------------------------------------
# Secret key used for signing JWT access/refresh tokens (Required in production)
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=dev_secret_jwt_sign_key_do_not_use_in_production
